# Copy to .env and fill in. .env is gitignored.
# Secrets only — non-secret config (LOG_LEVEL, TIDAL_COUNTRY_CODE, DEV_AUTH, ENABLE_LOGIN,
# redirect URIs, etc.) lives in docker-compose*.yml, not here.

# --- Sessions ---
# Random string; signs the session cookie. Change it.
SESSION_SECRET=change-this-to-a-long-random-string

# NOTE: app accounts are NOT configured here. Enable the login gate with ENABLE_LOGIN=true
# (in compose); the first visit then shows a setup screen to create the admin account, and
# the admin manages further users in-app. There are no USERNAME/PASSWORD env vars.

# --- Spotify ---
# From https://developer.spotify.com/dashboard. The redirect URI is set per-deployment in
# docker-compose*.yml (NOT here) and must match a Redirect URI registered on the app.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Tidal ---
# From https://developer.tidal.com/dashboard. PKCE flow → client ID is enough for a
# public app. Redirect URI is set per-deployment in docker-compose*.yml.
TIDAL_CLIENT_ID=
# Optional — only if your Tidal app is "confidential" (token endpoint then needs Basic
# auth). Leave blank for a public app; PKCE covers it.
TIDAL_CLIENT_SECRET=

# --- Dev auth bypass (NEVER enable in a real deploy) ---
# When DEV_AUTH=true (set in compose) and this refresh token is set, "Connect Spotify"
# skips the browser OAuth flow and seeds the session from the refresh token instead. The
# token's scopes must include playlist-read-private / playlist-read-collaborative.
SPOTIFY_DEV_REFRESH_TOKEN=
