# Copy to .env and fill in. .env is gitignored.

# --- Sessions ---
# Random string; signs the session cookie. Change it.
SESSION_SECRET=change-this-to-a-long-random-string

# --- App login gate ---
# The app is single-user: whoever reaches it controls the connected accounts. On a public
# origin, set ENABLE_LOGIN=true and a username/password so only you can get in.
ENABLE_LOGIN=false
USERNAME=admin
PASSWORD=change-me

# --- Spotify ---
# From https://developer.spotify.com/dashboard. The redirect URI is set per-deployment in
# docker-compose*.yml (NOT here) and must match a Redirect URI registered on the app.
# Spotify requires the 127.0.0.1 loopback literal (not "localhost") for local dev.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Tidal ---
# From https://developer.tidal.com/dashboard. PKCE flow → client ID is enough for a
# public app. Redirect URI is set per-deployment in docker-compose*.yml.
TIDAL_CLIENT_ID=
# Optional — only if your Tidal app is "confidential" (token endpoint then needs Basic
# auth). Leave blank for a public app; PKCE covers it.
TIDAL_CLIENT_SECRET=
# Market used for Tidal catalog calls.
TIDAL_COUNTRY_CODE=US

# --- Logging ---
LOG_LEVEL=INFO

# --- Dev auth bypass (NEVER enable in a real deploy) ---
# When DEV_AUTH=true and a refresh token is set, "Connect Spotify" skips the browser OAuth
# flow and seeds the session from the refresh token instead — handy when the Spotify portal
# is down or the redirect URI isn't registered. The refresh-token grant needs no redirect
# URI, so you can reuse another app's CLIENT_ID/CLIENT_SECRET + its refresh token (e.g. the
# DEV_REFRESH_TOKEN from another project's dev .env). The token's scopes must include
# playlist-read-private / playlist-read-collaborative.
DEV_AUTH=false
SPOTIFY_DEV_REFRESH_TOKEN=
