# Copy to .env and fill in. .env is gitignored.

# --- Sessions ---
# Random string; signs the session cookie. Change it.
SESSION_SECRET=change-this-to-a-long-random-string

# --- Spotify ---
# From https://developer.spotify.com/dashboard. The redirect URI is set per-deployment in
# docker-compose*.yml (NOT here) and must match a Redirect URI registered on the app.
# Spotify requires the 127.0.0.1 loopback literal (not "localhost") for local dev.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Tidal ---
# From https://developer.tidal.com/dashboard. PKCE flow → client ID only, no secret.
# Redirect URI is set per-deployment in docker-compose*.yml.
TIDAL_CLIENT_ID=
# Market used for Tidal catalog calls.
TIDAL_COUNTRY_CODE=US

# --- Logging ---
LOG_LEVEL=INFO
